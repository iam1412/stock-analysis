{
  "name": "stock-analysis",
  "version": "1.0.0",
  "private": true,
  "description": "รวมรายงานวิเคราะห์หุ้น (static site สำหรับ Cloudflare Pages)",
  "scripts": {
    "build": "node build.js",
    "test": "node test/check-reports.js",
    "test:self": "node test/self-test.js",
    "test:build": "node test/build-test.js",
    "test:engine": "node test/engine-exec.js",
    "test:skeleton": "node test/skeleton-test.js",
    "test:prices": "node test/update-prices-test.js",
    "check": "node test/check-reports.js",
    "check:site": "node test/check-site.js",
    "verify": "node test/check-reports.js && node build.js && node test/build-test.js && node test/engine-exec.js && node test/skeleton-test.js && node test/check-site.js",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:init:local": "wrangler d1 execute stockai_d1 --local --file=./schema.sql",
    "d1:init:remote": "wrangler d1 execute stockai_d1 --remote --file=./schema.sql",
    "d1:migrate:local": "wrangler d1 execute stockai_d1 --local --file=./migrate-votes.sql",
    "d1:migrate:remote": "wrangler d1 execute stockai_d1 --remote --file=./migrate-votes.sql"
  },
  "devDependencies": {
    "wrangler": "^4.36.0"
  },
  "engines": {
    "node": ">=18"
  }
}
