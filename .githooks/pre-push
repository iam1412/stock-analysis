#!/bin/sh
# pre-push hook — บล็อกการ push ถ้ารายงานใน reports/ ไม่ผ่าน quality gate
# เปิดใช้ครั้งเดียวต่อ clone:  git config core.hooksPath .githooks
# ดู: test/check-reports.js, CLAUDE.md ข้อ 4

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$repo_root" || exit 0

# หา node (รองรับกรณีรันจาก GUI git ที่ PATH ไม่ครบ)
command -v node >/dev/null 2>&1 || { echo "⚠️  pre-push: ไม่พบ node — ข้ามการตรวจ (ควรตรวจเองด้วย npm test)"; exit 0; }

block() {
  echo ""
  echo "❌ push ถูกบล็อก: $1 ไม่ผ่าน (ดูปัญหาด้านบน)"
  echo "   แก้ให้ผ่าน แล้วลองใหม่  •  ข้ามชั่วคราว (ไม่แนะนำ): git push --no-verify"
  exit 1
}

echo "🔍 pre-push 1/6: ตรวจคุณภาพรายงาน (check-reports)…"
node test/check-reports.js || block "report quality gate"

echo "🔧 pre-push 2/6: build dist/ …"
node build.js >/dev/null || block "build"

echo "🧪 pre-push 3/6: unit-test build.js (เครดิตโมเดล + freshHash)…"
node test/build-test.js >/dev/null || block "build-test"

echo "⚙️  pre-push 4/6: รัน engine ทุกรายงานใน mock DOM (engine-exec)…"
node test/engine-exec.js >/dev/null || block "engine execution gate"

echo "🧱 pre-push 5/6: โครงต้นแบบ TH/US เติมแล้วผ่าน gate (skeleton-test)…"
node test/skeleton-test.js >/dev/null || block "skeleton template gate"

echo "🌐 pre-push 6/6: ตรวจความสมบูรณ์เว็บไซต์ (check-site)…"
node test/check-site.js || block "site integrity gate"

exit 0
